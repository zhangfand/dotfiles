# Top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
max_line_length = 100

# Rust files
[*.rs]
indent_style = space
# Use 4 spaces for indentation in Rust code
indent_size = 4

# TOML files (Cargo manifests)
[*.toml]
indent_style = space
# TOML files often use 2 spaces for indentation
indent_size = 4

